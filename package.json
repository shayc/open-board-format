{
  "name": "@shayc/open-board-format",
  "type": "module",
  "version": "0.1.1",
  "description": "Parse, validate, and create Open Board Format (OBF/OBZ) files for AAC applications.",
  "author": "Shay Cojocaru <shayc@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/shayc/open-board-format#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shayc/open-board-format.git"
  },
  "bugs": {
    "url": "https://github.com/shayc/open-board-format/issues"
  },
  "keywords": [
    "aac",
    "open-board-format",
    "communication-board"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run pack:check",
    "pack:check": "publint --strict",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  }
}
