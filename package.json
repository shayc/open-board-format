{
  "name": "@shayc/open-board-format",
  "version": "1.0.2",
  "description": "A TypeScript toolkit for Open Board Format — the open standard for Augmentative and Alternative Communication (AAC) boards.",
  "license": "MIT",
  "author": "Shay Cojocaru <shayc@outlook.com>",
  "homepage": "https://github.com/shayc/open-board-format#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shayc/open-board-format.git"
  },
  "bugs": {
    "url": "https://github.com/shayc/open-board-format/issues"
  },
  "keywords": [
    "aac",
    "aac-board",
    "assistive-technology",
    "communication-board",
    "obf",
    "obz",
    "open-board-format"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs/external/open-board-format.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "tsdown": "^0.22.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
